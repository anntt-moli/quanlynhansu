<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg">


    <RelativeLayout
        android:id="@+id/header_vt"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/teal_primary"
        android:paddingHorizontal="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Vị Trí Làm Việc"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/fab_them_vt"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_fab"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"/>
    </RelativeLayout>


    <LinearLayout
        android:id="@+id/header_bang"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_below="@id/header_vt"
        android:orientation="horizontal"
        android:background="@color/teal_light"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:layout_width="55dp"
            android:layout_height="wrap_content"
            android:text="ID"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/teal_primary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tên vị trí"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/teal_primary"/>

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="Mức lương"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/teal_primary"/>

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Thao tác"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/teal_primary"
            android:gravity="center"/>
    </LinearLayout>


    <ListView
        android:id="@+id/listview_vi_tri"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_bang"
        android:divider="@color/gray_border"
        android:dividerHeight="1dp"/>

</RelativeLayout>