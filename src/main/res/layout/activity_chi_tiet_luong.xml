<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_bg">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/teal_primary"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/btn_back_luong"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chi tiết lương"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thông tin NV -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_border"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:id="@+id/tv_avatar_ct_luong"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_avatar"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:id="@+id/tv_ten_ct_luong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                    <TextView
                        android:id="@+id/tv_vitri_ct_luong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/gray_text"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tv_thang_ct_luong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- CHẤM CÔNG -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_border"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱  CHẤM CÔNG"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_ct_co_mat" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="22sp"
                            android:textStyle="bold" android:textColor="@color/status_con_han"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Có mặt" android:textSize="11sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_ct_nghi_phep" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="22sp"
                            android:textStyle="bold" android:textColor="@color/badge_thoi_vu"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Nghỉ phép" android:textSize="11sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_ct_vang" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="22sp"
                            android:textStyle="bold" android:textColor="@color/status_het_han"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Vắng" android:textSize="11sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- PHÉP NĂM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_border"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅  PHÉP NĂM"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="12" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Phép năm" android:textSize="11sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_ct_phep_da_dung" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="22sp"
                            android:textStyle="bold" android:textColor="@color/badge_thoi_vu"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Đã dùng" android:textSize="11sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_ct_phep_con_lai" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="22sp"
                            android:textStyle="bold" android:textColor="@color/teal_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Còn lại" android:textSize="11sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- LƯƠNG -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_border"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰  LƯƠNG"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"/>
                <include layout="@layout/row_luong_detail" />
            </LinearLayout>

            <!-- Lương thực nhận -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/teal_primary"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lương thực nhận"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tv_ct_thuc_nhan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>