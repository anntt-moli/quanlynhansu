<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingVertical="6dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Lương vị trí" android:textSize="13sp"
            android:textColor="@color/gray_text"/>
        <TextView android:id="@+id/tv_row_luong_vt" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingVertical="6dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Ngày chuẩn" android:textSize="13sp"
            android:textColor="@color/gray_text"/>
        <TextView android:id="@+id/tv_row_ngay_chuan" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingVertical="6dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Ngày công thực" android:textSize="13sp"
            android:textColor="@color/gray_text"/>
        <TextView android:id="@+id/tv_row_ngay_cong" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingVertical="6dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Hệ số công" android:textSize="13sp"
            android:textColor="@color/gray_text"/>
        <TextView android:id="@+id/tv_row_he_so" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingVertical="6dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Thưởng chuyên cần" android:textSize="13sp"
            android:textColor="@color/gray_text"/>
        <TextView android:id="@+id/tv_row_thuong" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingVertical="6dp"
        android:id="@+id/row_tang_ca_t7cn" android:visibility="gone">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Tăng ca T7/CN (×2)" android:textSize="13sp"
            android:textColor="@color/status_sap_het"/>
        <TextView android:id="@+id/tv_row_tang_ca_t7cn" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/status_sap_het"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingVertical="6dp"
        android:id="@+id/row_tang_ca_le" android:visibility="gone">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Tăng ca ngày lễ (×3)" android:textSize="13sp"
            android:textColor="@color/status_het_han"/>
        <TextView android:id="@+id/tv_row_tang_ca_le" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/status_het_han"/>
    </LinearLayout>
</LinearLayout>