<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_bg">

    <!-- Header xanh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/teal_primary"
        android:padding="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chấm Công"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tv_ngay_hien_thi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Chọn ngày -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_border"
                android:padding="12dp"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅  Ngày"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/btn_ngay_truoc"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="◄"
                        android:textSize="18sp"
                        android:textColor="@color/teal_primary"
                        android:clickable="true"
                        android:focusable="true"/>
                    <EditText
                        android:id="@+id/tv_ngay"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_card_border"
                        android:inputType="number"
                        android:maxLength="2"/>
                    <EditText
                        android:id="@+id/tv_thang"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_card_border"
                        android:inputType="number"
                        android:maxLength="2"
                        android:layout_marginHorizontal="6dp"/>
                    <EditText
                        android:id="@+id/tv_nam"
                        android:layout_width="64dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_card_border"
                        android:inputType="number"
                        android:maxLength="4"
                        android:imeOptions="actionDone"/>
                    <TextView
                        android:id="@+id/btn_ngay_sau"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="►"
                        android:textSize="18sp"
                        android:textColor="@color/teal_primary"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nhập ngày rồi nhấn Tải"
                        android:textSize="11sp"
                        android:textColor="@color/gray_text"/>
                    <TextView
                        android:id="@+id/btn_tai_ngay"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Tải"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@color/teal_primary"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"/>
                    <TextView
                        android:id="@+id/btn_hom_nay"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:text="Hôm nay"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/teal_primary"
                        android:background="@drawable/bg_card_border"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Banner ngày đặc biệt -->
            <LinearLayout
                android:id="@+id/banner_ngay_dac_biet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_border"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tv_banner_ngay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/btn_toggle_nghi_le"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:textSize="12sp"
                    android:background="@drawable/bg_card_border"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Thống kê -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_border"
                android:padding="12dp"
                android:layout_marginBottom="10dp">
                <TextView
                    android:id="@+id/tv_thong_bao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠ Chưa có dữ liệu"
                    android:textSize="13sp"
                    android:textColor="@color/status_sap_het"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_co_mat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_con_han"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Có mặt"
                            android:textSize="11sp"
                            android:textColor="@color/gray_text"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_nghi_phep"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/badge_thoi_vu"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nghỉ phép"
                            android:textSize="11sp"
                            android:textColor="@color/gray_text"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_vang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_het_han"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vắng"
                            android:textSize="11sp"
                            android:textColor="@color/gray_text"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Nút nhanh — 2 hàng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:id="@+id/btn_tat_ca_co_mat"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="✓ Tất cả có mặt"
                    android:textSize="12sp"
                    android:textColor="@color/teal_primary"
                    android:background="@drawable/bg_card_border"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/btn_tat_ca_nghi_le"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="🎌 Tất cả nghỉ lễ"
                    android:textSize="12sp"
                    android:textColor="@color/status_het_han"
                    android:background="@drawable/bg_card_border"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:id="@+id/btn_chep_ngay_truoc"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="📋 Chép ngày trước"
                    android:textSize="12sp"
                    android:textColor="@color/teal_primary"
                    android:background="@drawable/bg_card_border"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/btn_cham_hang_loat"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="📅 Chấm hàng loạt"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:background="@color/teal_primary"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Danh sách nhân viên -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_border"
                android:padding="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Danh sách nhân viên"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                    <TextView
                        android:id="@+id/tv_da_cham"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/gray_text"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/container_ds_cham_cong"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Nút LƯU cố định ở đáy -->
    <TextView
        android:id="@+id/btn_luu_cham_cong"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center"
        android:text="LƯU"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@color/teal_primary"
        android:layout_margin="12dp"
        android:clickable="true"
        android:focusable="true"/>
</LinearLayout>