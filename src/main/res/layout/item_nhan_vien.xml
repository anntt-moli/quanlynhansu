<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/white"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="8dp"
    android:padding="12dp"
    android:elevation="2dp">


    <TextView
        android:id="@+id/tv_stt"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/gray_text"
        android:gravity="center"
        android:layout_marginEnd="6dp"/>


    <TextView
        android:id="@+id/tv_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_avatar"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"/>


    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_ten_nv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_ma_nv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_text"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_vi_tri_nv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/teal_primary"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_trang_thai_hd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>
    </LinearLayout>


    <TextView
        android:id="@+id/tv_badge_luong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_badge_high"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:text="Cao"
        android:textColor="@color/badge_high"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"/>

</LinearLayout>