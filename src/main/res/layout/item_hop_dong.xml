<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:layout_marginHorizontal="2dp"
    android:background="@drawable/bg_card_border">

    <TextView
        android:id="@+id/tv_loai_hd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/white"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bắt đầu"
                android:textSize="11sp"
                android:textColor="@color/gray_text"/>
            <TextView
                android:id="@+id/tv_ngay_bat_dau"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  →  "
            android:textSize="14sp"
            android:textColor="@color/gray_text"
            android:layout_gravity="bottom"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kết thúc"
                android:textSize="11sp"
                android:textColor="@color/gray_text"/>
            <TextView
                android:id="@+id/tv_ngay_ket_thuc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_trang_thai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/btn_sua_hd"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✏️ Sửa"
            android:textSize="13sp"
            android:textColor="@color/teal_primary"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"/>
        <TextView
            android:id="@+id/btn_xoa_hd"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🗑️ Xóa"
            android:textSize="13sp"
            android:textColor="@color/red_danger"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</LinearLayout>